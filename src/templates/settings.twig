    id: 'importDirectory',
    name: 'importDirectory',
    value: settings.importDirectory,
    suggestEnvVars: true,
    suggestAliases: true,
    errors: settings.getErrors('importDirectory'),
}) }}
{{ forms.autosuggestField({
    label: 'Log Directory' | t('_priceadjuster'),
    instructions: 'Directory where log files are written. Supports Craft aliases and environment variables.' | t('_priceadjuster'),
    id: 'logDirectory',
    name: 'logDirectory',
