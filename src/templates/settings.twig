    name: 'rulesDirectory',
    value: settings.rulesDirectory,
    suggestEnvVars: true,
    suggestAliases: true,
    errors: settings.getErrors('rulesDirectory'),
}) }}
{{ forms.autosuggestField({
    label: 'Export Directory' | t('_priceadjuster'),
