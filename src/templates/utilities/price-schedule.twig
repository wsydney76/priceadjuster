{% if ruleList is not null %}
    {# ── Rule index ── #}
    {% if ruleList is empty %}
        <p class="zilch">No price schedule records found.</p>
    {% else %}
        <h2>Price Schedule Rules</h2>
        <table class="data full collapsible">
            <thead>
                <tr>
                    <th>Rule</th>
                    <th class="thin" style="text-align:right;">Total</th>
                    <th class="thin" style="text-align:right;">Pending</th>
                    <th class="thin" style="text-align:right;">Applied</th>
                    <th class="thin"></th>
                </tr>
            </thead>
            <tbody>
                {% for row in ruleList %}
                    <tr>
                        <td style="display: flex; align-items: center">
                            <a class="go" href="{{ url(craft.app.request.pathInfo, {rule: row.ruleName}) }}">
                                {{ row.ruleName }}
                            </a>
                            {% if datesByRule[row.ruleName] is defined %}
                                <div style="margin-left: 24px; margin-top:.35rem; display:flex; flex-wrap:wrap; gap:.35rem;">
                                    {% for dr in datesByRule[row.ruleName] %}
                                        <a href="{{ url(craft.app.request.pathInfo, {rule: row.ruleName, date: dr.effectiveDate}) }}"
                                           style="font-size:.75rem; padding:.1rem .45rem; border-radius:3px; background:var(--gray-100); color:var(--link-color); white-space:nowrap;"
                                           title="{{ dr.pending }} pending / {{ dr.applied }} applied">
                                            {{ dr.effectiveDate }}
                                        </a>
                                    {% endfor %}
                                </div>
                            {% endif %}
                        </td>
                        <td class="thin" style="text-align:right;">{{ row.total }}</td>
                        <td class="thin" style="text-align:right;">{{ row.pending }}</td>
                        <td class="thin" style="text-align:right;">{{ row.applied }}</td>
                        <td class="thin" style="text-align:right;">
                            <button type="button"
                                    class="btn small ps-delete-rule-btn"
                                    data-rule="{{ row.ruleName }}"
                                    data-total="{{ row.total }}"
                                    style="color:var(--red-600);">
                                Delete all
                            </button>
                        </td>
                    </tr>
                {% endfor %}
            </tbody>
        </table>
        <script>
        (function () {
            var deleteByRuleUrl = '{{ actionUrl('_priceadjuster/price-schedule/delete-by-rule') }}';
            document.querySelectorAll('.ps-delete-rule-btn').forEach(function (btn) {
                btn.addEventListener('click', function () {
                    var rule  = btn.dataset.rule;
                    var total = btn.dataset.total;
                    if (!confirm('Delete all ' + total + ' record(s) for rule "' + rule + '"? This cannot be undone.')) {
                        return;
                    }
                    btn.classList.add('loading');
                    btn.disabled = true;
                    var body = new FormData();
                    body.append(Craft.csrfTokenName, Craft.csrfTokenValue);
                    body.append('rule', rule);
                    fetch(deleteByRuleUrl, {
                        method: 'POST',
                        headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest', 'X-CSRF-Token': Craft.csrfTokenValue },
                        body: body,
                    })
                    .then(function (r) { return r.json(); })
                    .then(function (json) {
                        if (json.success) {
                            Craft.cp.displayNotice(json.message || 'Deleted.');
                            btn.closest('tr').remove();
                        } else {
                            Craft.cp.displayError(json.message || 'Delete failed.');
                        }
                    })
                    .catch(function () { Craft.cp.displayError('Delete failed.'); })
                    .finally(function () { btn.classList.remove('loading'); btn.disabled = false; });
                });
            });
        })();
        </script>
    {% endif %}
{% else %}
    {# ── Filtered by rule ── #}
    <h2 style="margin-bottom:1rem;">
        Rule: <strong>{{ currentRule }}</strong>
        {% if currentDate %}&nbsp;— Date: <strong>{{ currentDate }}</strong>{% endif %}
    </h2>

    {# ── Date filter bar ── #}
    {% if availableDates|length > 1 %}
        <div style="margin-bottom:1.5rem; display:flex; flex-wrap:wrap; gap:.4rem; align-items:center;">
            <span style="font-size:.8rem; color:var(--gray-500); margin-right:.25rem;">Filter by date:</span>
            <a href="{{ url(craft.app.request.pathInfo, {rule: currentRule}) }}"
               style="font-size:.8rem; padding:.2rem .5rem; border-radius:3px;
                      background:{{ currentDate is null or currentDate == '' ? 'var(--blue-600)' : 'var(--gray-100)' }};
                      color:{{ currentDate is null or currentDate == '' ? '#fff' : 'var(--link-color)' }};">
                All
            </a>
            {% for d in availableDates %}
                <a href="{{ url(craft.app.request.pathInfo, {rule: currentRule, date: d}) }}"
                   style="font-size:.8rem; padding:.2rem .5rem; border-radius:3px;
                          background:{{ currentDate == d ? 'var(--blue-600)' : 'var(--gray-100)' }};
                          color:{{ currentDate == d ? '#fff' : 'var(--link-color)' }};">
                    {{ d }}
                </a>
            {% endfor %}
        </div>
    {% endif %}

    {% if grouped is empty %}
        <p class="zilch">No price schedule records found for this rule.</p>
    {% else %}
        {% for date, records in grouped %}
            {% set pending = records | filter(r => r.appliedAt is null) %}
            {% set applied = records | filter(r => r.appliedAt is not null) %}
            <h2 style="margin-top: 1.5rem;">
                Effective date: <strong>{{ date }}</strong>
                <small style="font-weight:normal; margin-left:.5rem;">
                    {{ records|length }} record(s){% if applied|length %}, {{ applied|length }} applied{% endif %}
                </small>
            </h2>
            {% if pending is not empty %}
                <form method="post" class="price-schedule-form">
                    {{ csrfInput() }}
                    {{ actionInput('_priceadjuster/price-schedule/batch-update') }}
                    <table class="data full collapsible" style="margin-bottom: 1rem;">
                        <thead>
                            <tr>
                                <th class="thin" style="width:1rem;"><input type="checkbox" class="ps-select-all" title="Select all"></th>
                                <th>Title / SKU</th>
                                <th class="thin">Old Price</th>
                                <th class="thin">New Price</th>
                                <th class="thin">Old Promo</th>
                                <th class="thin">New Promo</th>
                                <th>Rule</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for record in pending %}
                                {% set editUrl = productEditUrls[record.variantId] ?? null %}
                                <input type="hidden" name="updates[{{ loop.index0 }}][id]" value="{{ record.id }}">
                                <tr data-record-id="{{ record.id }}">
                                    <td class="thin"><input type="checkbox" class="ps-delete-cb" value="{{ record.id }}"></td>
                                    <td>
                                        {% if editUrl %}
                                            <a class="go" href="{{ editUrl }}#tab03-variants" target="_blank"><strong>{{ record.title }}</strong></a>
                                        {% else %}
                                            <strong>{{ record.title }}</strong>
                                        {% endif %}
                                        <br><small class="light">{{ record.sku }}</small>
                                    </td>
                                    <td class="thin" style="white-space:nowrap;">{{ record.oldPrice|number_format(2, '.', '') }}</td>
                                    <td class="thin">
                                        <input
                                            class="text"
                                            type="number"
                                            step="0.01"
                                            min="0.01"
                                            name="updates[{{ loop.index0 }}][newPrice]"
                                            value="{{ record.newPrice|number_format(2, '.', '') }}"
                                            style="width: 90px; text-align: right;"
                                        >
                                    </td>
                                    <td class="thin" style="white-space:nowrap;">{{ record.oldPromotionalPrice is not null ? record.oldPromotionalPrice|number_format(2, '.', '') : '—' }}</td>
                                    <td class="thin">
                                        <input
                                            class="text"
                                            type="number"
                                            step="0.01"
                                            min="0.01"
                                            name="updates[{{ loop.index0 }}][newPromotionalPrice]"
                                            value="{{ record.newPromotionalPrice is not null ? record.newPromotionalPrice|number_format(2, '.', '') : '' }}"
                                            placeholder="—"
                                            style="width: 90px; text-align: right;"
                                        >
                                    </td>
                                    <td><small>{{ record.ruleLabel }}</small></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                    <div style="position:sticky; bottom:0; z-index:10; background:var(--gray-200); border-top:1px solid var(--hairline-color); margin:0 -1.5rem; padding:.75rem 2rem 1rem; margin-bottom:1rem;">
                        <button type="submit" class="btn submit">Save {{ date }}</button>
                        <button type="button" class="btn ps-delete-btn" style="margin-left:.5rem; color: var(--red-600);">Delete selected</button>
                        <button type="button" class="btn" style="margin-left:.5rem;" onclick="location.reload()">↺ Refresh</button>
                    </div>
                </form>
            {% endif %}
            {% if applied is not empty %}
                <details style="margin-bottom: 2rem;">
                    <summary style="cursor:pointer; color: var(--gray-500);">
                        {{ applied|length }} applied record(s) for {{ date }}
                    </summary>
                    <table class="data full collapsible" style="margin-top:.5rem; opacity:.7;">
                        <thead>
                            <tr>
                                <th>Title / SKU</th>
                                <th class="thin">Old Price</th>
                                <th class="thin">New Price</th>
                                <th class="thin">Old Promo</th>
                                <th class="thin">New Promo</th>
                                <th class="thin">Applied At</th>
                                <th>Rule</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for record in applied %}
                                {% set editUrl = productEditUrls[record.variantId] ?? null %}
                                <tr>
                                    <td>
                                        {% if editUrl %}
                                            <a class="go" href="{{ editUrl }}" target="_blank"><strong>{{ record.title }}</strong></a>
                                        {% else %}
                                            <strong>{{ record.title }}</strong>
                                        {% endif %}
                                        <br><small class="light">{{ record.sku }}</small>
                                    </td>
                                    <td class="thin">{{ record.oldPrice|number_format(2, '.', '') }}</td>
                                    <td class="thin">{{ record.newPrice|number_format(2, '.', '') }}</td>
                                    <td class="thin">{{ record.oldPromotionalPrice is not null ? record.oldPromotionalPrice|number_format(2, '.', '') : '—' }}</td>
                                    <td class="thin">{{ record.newPromotionalPrice is not null ? record.newPromotionalPrice|number_format(2, '.', '') : '—' }}</td>
                                    <td class="thin">
                                        <span class="status live"></span>
                                        <small>{{ record.appliedAt }}</small>
                                    </td>
                                    <td><small>{{ record.ruleLabel }}</small></td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </details>
            {% endif %}
        {% endfor %}
        <script>
        (function () {
            var saveUrl   = '{{ actionUrl('_priceadjuster/price-schedule/batch-update') }}';
            var deleteUrl = '{{ actionUrl('_priceadjuster/price-schedule/delete-selected') }}';

            // Select-all toggle
            document.querySelectorAll('.ps-select-all').forEach(function (toggle) {
                toggle.addEventListener('change', function () {
                    var table = toggle.closest('table');
                    table.querySelectorAll('.ps-delete-cb').forEach(function (cb) {
                        cb.checked = toggle.checked;
                    });
                });
            });

            function postJson(url, body, onSuccess, onError, onFinally) {
                fetch(url, {
                    method: 'POST',
                    headers: {
                        'Accept': 'application/json',
                        'X-Requested-With': 'XMLHttpRequest',
                        'X-CSRF-Token': Craft.csrfTokenValue,
                    },
                    body: body,
                })
                .then(function (r) { return r.json(); })
                .then(function (json) {
                    if (json.success) { onSuccess(json); } else { onError(json); }
                })
                .catch(function () { onError(null); })
                .finally(onFinally);
            }

            // Save form
            document.querySelectorAll('.price-schedule-form').forEach(function (form) {
                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    var btn = form.querySelector('button[type=submit]');
                    btn.classList.add('loading');
                    btn.disabled = true;
                    postJson(
                        saveUrl,
                        new FormData(form),
                        function (json) { Craft.cp.displayNotice(json.message || 'Saved.'); },
                        function (json) { Craft.cp.displayError((json && json.message) || 'An error occurred.'); },
                        function () { btn.classList.remove('loading'); btn.disabled = false; }
                    );
                });

                // Delete selected
                form.querySelector('.ps-delete-btn').addEventListener('click', function () {
                    var checked = Array.from(form.querySelectorAll('.ps-delete-cb:checked'));
                    if (!checked.length) {
                        Craft.cp.displayError('No rows selected.');
                        return;
                    }
                    if (!confirm('Delete ' + checked.length + ' record(s)? This cannot be undone.')) {
                        return;
                    }
                    var deleteBtn = this;
                    deleteBtn.classList.add('loading');
                    deleteBtn.disabled = true;
                    var body = new FormData();
                    body.append(Craft.csrfTokenName, Craft.csrfTokenValue);
                    checked.forEach(function (cb) { body.append('ids[]', cb.value); });
                    postJson(
                        deleteUrl,
                        body,
                        function (json) {
                            Craft.cp.displayNotice(json.message || 'Deleted.');
                            // window.location.reload();
                        },
                        function (json) { Craft.cp.displayError((json && json.message) || 'Delete failed.'); },
                        function () { deleteBtn.classList.remove('loading'); deleteBtn.disabled = false; }
                    );
                });
            });
        })();
        </script>
    {% endif %}
{% endif %}
