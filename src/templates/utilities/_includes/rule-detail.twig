{# ── Filtered by rule ── #}
<h2 style="margin-bottom:1rem;">
    Rule: <strong>{{ currentRule }}</strong>
    {% if currentDate %}&nbsp;— Date: <strong>{{ currentDate }}</strong>{% endif %}
</h2>

{# ── Date filter bar ── #}
{% if availableDates|length > 1 %}
    <div style="margin-bottom:1.5rem; display:flex; flex-wrap:wrap; gap:.4rem; align-items:center;">
        <span style="font-size:.8rem; color:var(--gray-500); margin-right:.25rem;">Filter by date:</span>
        <a href="{{ url(craft.app.request.pathInfo, {rule: currentRule}) }}"
           style="font-size:.8rem; padding:.2rem .5rem; border-radius:3px;
                   background:{{ currentDate is null or currentDate == '' ? 'var(--blue-600)' : 'var(--gray-100)' }};
                   color:{{ currentDate is null or currentDate == '' ? '#fff' : 'var(--link-color)' }};">
            All
        </a>
        {% for d in availableDates %}
            <a href="{{ url(craft.app.request.pathInfo, {rule: currentRule, date: d}) }}"
               style="font-size:.8rem; padding:.2rem .5rem; border-radius:3px;
                       background:{{ currentDate == d ? 'var(--blue-600)' : 'var(--gray-100)' }};
                       color:{{ currentDate == d ? '#fff' : 'var(--link-color)' }};">
                {{ d }}
            </a>
        {% endfor %}
    </div>
{% endif %}

{% if grouped is empty %}
    <p class="zilch">No price schedule records found for this rule.</p>
{% else %}
    {% for date, records in grouped %}
        {% set pending = records | filter(r => r.appliedAt is null) %}
        {% set applied = records | filter(r => r.appliedAt is not null) %}
        <h2 style="margin-top: 1.5rem;">
            Effective date: <strong>{{ date }}</strong>
            <small style="font-weight:normal; margin-left:.5rem;">
                {{ records|length }} record(s){% if applied|length %}, {{ applied|length }} applied{% endif %}
            </small>
        </h2>
        {% if pending is not empty %}
            <form method="post" class="price-schedule-form">
                {{ csrfInput() }}
                {{ actionInput('_priceadjuster/price-schedule/batch-update') }}
                <table class="data full collapsible" style="margin-bottom: 1rem;">
                    <thead>
                    <tr>
                        <th class="thin" style="width:1rem;"><input type="checkbox" class="ps-select-all"
                                                                    title="Select all"></th>
                        <th>Title / SKU</th>
                        <th class="thin">Old Price</th>
                        <th class="thin">New Price</th>
                        <th class="thin">Old Promo</th>
                        <th class="thin">New Promo</th>
                        <th>Rule</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for record in pending %}
                        {% set editUrl = productEditUrls[record.variantId] ?? null %}
                        <input type="hidden" name="updates[{{ loop.index0 }}][id]" value="{{ record.id }}">
                        <tr data-record-id="{{ record.id }}">
                            <td class="thin"><input type="checkbox" class="ps-delete-cb" value="{{ record.id }}"></td>
                            <td>
                                {% if editUrl %}
                                    <a class="go" href="{{ editUrl }}#tab03-variants"
                                       target="_blank"><strong>{{ record.title }}</strong></a>
                                {% else %}
                                    <strong>{{ record.title }}</strong>
                                {% endif %}
                                <br><small class="light">{{ record.sku }}</small>
                            </td>
                            <td class="thin"
                                style="white-space:nowrap;">{{ record.oldPrice|number_format(2, '.', '') }}</td>
                            <td class="thin">
                                <input
                                        class="text"
                                        type="number"
                                        step="0.01"
                                        min="0.01"
                                        name="updates[{{ loop.index0 }}][newPrice]"
                                        value="{{ record.newPrice|number_format(2, '.', '') }}"
                                        style="width: 90px; text-align: right;"
                                >
                            </td>
                            <td class="thin"
                                style="white-space:nowrap;">{{ record.oldPromotionalPrice is not null ? record.oldPromotionalPrice|number_format(2, '.', '') : '—' }}</td>
                            <td class="thin">
                                <input
                                        class="text"
                                        type="number"
                                        step="0.01"
                                        min="0.01"
                                        name="updates[{{ loop.index0 }}][newPromotionalPrice]"
                                        value="{{ record.newPromotionalPrice is not null ? record.newPromotionalPrice|number_format(2, '.', '') : '' }}"
                                        placeholder="—"
                                        style="width: 90px; text-align: right;"
                                >
                            </td>
                            <td><small>{{ record.ruleLabel }}</small></td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
                <div style="position:sticky; bottom:0; z-index:10; background:var(--gray-200); border-top:1px solid var(--hairline-color); margin:0 -1.5rem; padding:.75rem 2rem 1rem; margin-bottom:1rem; display:flex; flex-wrap:wrap; align-items:center; gap:.5rem;">
                    <button type="submit" class="btn submit">Save {{ date }}</button>
                    <button type="button" class="btn ps-delete-btn" style="color: var(--red-600);">Delete selected</button>
                    <span style="display:flex; align-items:center; gap:.35rem; margin-left:.5rem;">
                        <input
                            type="text"
                            class="text ps-title-filter-input"
                            placeholder="Filter by title…"
                            style="width:160px; font-size:.85rem;"
                        >
                        <button type="button" class="btn ps-select-by-title-btn">Filter by title</button>
                        <button type="button" class="btn ps-clear-filter-btn" style="display:none;">Clear filter</button>
                    </span>
                    <span style="margin-left:.5rem; display:flex; align-items:center; gap:.35rem;">
                        <input
                                type="text"
                                class="text ps-new-date-input"
                                placeholder="yyyy-mm-dd"
                                pattern="\d{4}-\d{2}-\d{2}"
                                maxlength="10"
                                data-rule="{{ currentRule }}"
                                data-old-date="{{ date }}"
                                style="width:120px; font-size:.85rem;"
                        >
                        <button type="button" class="btn ps-update-date-btn">Update effective date</button>
                    </span>
                </div>
            </form>
        {% endif %}
        {% if applied is not empty %}
            <details style="margin-bottom: 2rem;">
                <summary style="cursor:pointer; color: var(--gray-500);">
                    {{ applied|length }} applied record(s) for {{ date }}
                </summary>
                <table class="data full collapsible" style="margin-top:.5rem; opacity:.7;">
                    <thead>
                    <tr>
                        <th>Title / SKU</th>
                        <th class="thin">Old Price</th>
                        <th class="thin">New Price</th>
                        <th class="thin">Old Promo</th>
                        <th class="thin">New Promo</th>
                        <th class="thin">Applied At</th>
                        <th>Rule</th>
                    </tr>
                    </thead>
                    <tbody>
                    {% for record in applied %}
                        {% set editUrl = productEditUrls[record.variantId] ?? null %}
                        <tr>
                            <td>
                                {% if editUrl %}
                                    <a class="go" href="{{ editUrl }}"
                                       target="_blank"><strong>{{ record.title }}</strong></a>
                                {% else %}
                                    <strong>{{ record.title }}</strong>
                                {% endif %}
                                <br><small class="light">{{ record.sku }}</small>
                            </td>
                            <td class="thin">{{ record.oldPrice|number_format(2, '.', '') }}</td>
                            <td class="thin">{{ record.newPrice|number_format(2, '.', '') }}</td>
                            <td class="thin">{{ record.oldPromotionalPrice is not null ? record.oldPromotionalPrice|number_format(2, '.', '') : '—' }}</td>
                            <td class="thin">{{ record.newPromotionalPrice is not null ? record.newPromotionalPrice|number_format(2, '.', '') : '—' }}</td>
                            <td class="thin">
                                <span class="status live"></span>
                                <small>{{ record.appliedAt }}</small>
                            </td>
                            <td><small>{{ record.ruleLabel }}</small></td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>
            </details>
        {% endif %}
    {% endfor %}
{% endif %}

