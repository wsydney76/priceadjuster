{# ── Rule index ── #}
{% if ruleList is empty %}
    <p class="zilch">No price schedule records found.</p>
{% else %}
    <h2>Price Schedule Rules</h2>
    <table class="data full collapsible">
        <thead>
        <tr>
            <th>Rule</th>
            <th class="thin ps-col-number">Total</th>
            <th class="thin ps-col-number">Pending</th>
            <th class="thin ps-col-number">Applied</th>
            <th class="thin"></th>
        </tr>
        </thead>
        <tbody>
        {% for row in ruleList %}
            <tr>
                <td class="ps-rule-name-cell">
                    <a class="go" href="{{ url(craft.app.request.pathInfo, {rule: row.ruleName}) }}">
                        {{ row.ruleName }}
                    </a>
                    {% if datesByRule[row.ruleName] is defined %}
                        <div class="ps-date-badges">
                            {% for dr in datesByRule[row.ruleName] %}
                                <a href="{{ url(craft.app.request.pathInfo, {rule: row.ruleName, date: dr.effectiveDate}) }}"
                                   class="ps-date-badge"
                                   title="{{ dr.pending }} pending / {{ dr.applied }} applied">
                                    {{ dr.effectiveDate }}
                                </a>
                            {% endfor %}
                        </div>
                    {% endif %}
                </td>
                <td class="thin ps-col-number">{{ row.total }}</td>
                <td class="thin ps-col-number">{{ row.pending }}</td>
                <td class="thin ps-col-number">{{ row.applied }}</td>
                <td class="thin ps-col-number">
                    <button type="button"
                            class="btn small ps-delete-rule-btn ps-btn-danger"
                            data-rule="{{ row.ruleName }}"
                            data-total="{{ row.total }}">
                        Delete all
                    </button>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}
