{# ── Rule File List ── #}
<div class="ps-toolbar-group" style="margin-bottom: 1.5rem;">
    <a href="{{ url(craft.app.request.pathInfo, {file: 'new'}) }}" class="btn submit">+ Create New Rule File</a>
</div>

<p class="light" style="margin-bottom:1rem;">
    Rules directory: <code>{{ rulesDir }}</code>
</p>

{% if files is empty %}
    <p class="zilch">No rule files found in the rules directory.</p>
{% else %}
    <table class="data full collapsible">
        <thead>
        <tr>
            <th>File</th>
            <th class="thin" style="text-align:right;">Entries</th>
            <th class="thin" style="text-align:right;">DB Records</th>
            <th class="thin" style="text-align:right;">Applied</th>
            <th class="thin">Last Modified</th>
            <th class="thin"></th>
        </tr>
        </thead>
        <tbody>
        {% for file in files %}
            <tr>
                <td>
                    <a class="go" href="{{ url(craft.app.request.pathInfo, {file: file.name}) }}">
                        {{ file.name }}.json
                    </a>
                    {% if file.parseError %}
                        <span class="status expired" title="File contains invalid JSON"></span>
                        <small class="light"> invalid JSON</small>
                    {% endif %}
                </td>
                <td class="thin" style="text-align:right;">{{ file.entryCount }}</td>
                {% set counts = recordCounts[file.name] ?? {total: 0, applied: 0} %}
                <td class="thin" style="text-align:right;">{{ counts.total ?: '' }}</td>
                <td class="thin" style="text-align:right;">{{ counts.applied ?: '' }}</td>
                <td class="thin">{{ file.modified|date('Y-m-d H:i') }}</td>
                <td class="thin">
                    {% set safeId = file.name|replace({'.': '-', ' ': '_'}) %}
                    <button type="button" class="btn small menubtn">Actions</button>
                    <div class="menu">
                        <ul>
                            <li><a href="{{ cpUrl('utilities/price-schedule', {rule: file.name}) }}">View Schedule</a></li>
                        </ul>
                        <hr>
                        <ul>
                            {% if not file.parseError %}
                                <li><a href="javascript:;" class="ps-stage-rule-btn" data-rule="{{ file.name }}">Stage</a></li>
                                <li><a href="javascript:;" class="ps-stage-rule-btn" data-rule="{{ file.name }}" data-replace="1">Stage + Replace</a></li>
                            {% else %}
                                <li><span class="menu-option disabled" title="File contains invalid JSON">Stage (invalid JSON)</span></li>
                            {% endif %}
                            <li><a href="javascript:;" onclick="
                                var n = prompt('New file name (without .json):', '{{ file.name }}-copy');
                                if (!n) return;
                                var f = document.getElementById('dup-{{ safeId }}');
                                f.querySelector('[name=newFileName]').value = n.trim();
                                f.submit();
                            ">Duplicate</a></li>
                        </ul>
                        <hr>
                        <ul>
                            <li><a href="javascript:;" class="error ps-delete-rule-btn" data-rule="{{ file.name }}" data-total="all">Delete Records</a></li>
                            <li><a href="javascript:;" class="error" onclick="
                                if (!confirm('Delete {{ file.name }}.json? This cannot be undone.')) return;
                                document.getElementById('delfile-{{ safeId }}').submit();
                            ">Delete File</a></li>
                        </ul>
                    </div>

                    {# Hidden forms for POST-only actions #}
                    <form id="dup-{{ safeId }}" method="post" style="display:none;">
                        {{ csrfInput() }}
                        {{ actionInput('_priceadjuster/rule-file/duplicate') }}
                        <input type="hidden" name="fileName" value="{{ file.name }}">
                        <input type="hidden" name="newFileName" value="">
                    </form>
                    <form id="delfile-{{ safeId }}" method="post" style="display:none;">
                        {{ csrfInput() }}
                        {{ actionInput('_priceadjuster/rule-file/delete') }}
                        <input type="hidden" name="fileName" value="{{ file.name }}">
                    </form>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}
