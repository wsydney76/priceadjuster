{# ── Rule File List ── #}
<div class="ps-toolbar-group" style="margin-bottom: 1.5rem;">
    <a href="{{ url(craft.app.request.pathInfo, {file: 'new'}) }}" class="btn submit">+ Create New Rule File</a>
</div>

<p class="light" style="margin-bottom:1rem;">
    Rules directory: <code>{{ rulesDir }}</code>
</p>

{% if files is empty %}
    <p class="zilch">No rule files found in the rules directory.</p>
{% else %}
    <table class="data full collapsible">
        <thead>
        <tr>
            <th>File</th>
            <th class="thin" style="text-align:right;">Entries</th>
            <th class="thin" style="text-align:right;">DB Records</th>
            <th class="thin" style="text-align:right;">Applied</th>
            <th class="thin">Last Modified</th>
            <th class="thin"></th>
        </tr>
        </thead>
        <tbody>
        {% for file in files %}
            <tr>
                <td>
                    <a class="go" href="{{ url(craft.app.request.pathInfo, {file: file.name}) }}">
                        {{ file.name }}.json
                    </a>
                    {% if file.parseError %}
                        <span class="status expired" title="File contains invalid JSON"></span>
                        <small class="light"> invalid JSON</small>
                    {% endif %}
                </td>
                <td class="thin" style="text-align:right;">{{ file.entryCount }}</td>
                {% set counts = recordCounts[file.name] ?? {total: 0, applied: 0} %}
                <td class="thin" style="text-align:right;">{{ counts.total ?: '' }}</td>
                <td class="thin" style="text-align:right;">{{ counts.applied ?: '' }}</td>
                <td class="thin">{{ file.modified|date('Y-m-d H:i') }}</td>
                <td class="thin" style="white-space:nowrap;">
                    <a href="{{ cpUrl('utilities/price-schedule', {rule: file.name}) }}"
                       class="btn small">View Schedule</a>
                    <button type="button"
                            class="btn small ps-stage-rule-btn"
                            data-rule="{{ file.name }}"
                            {% if file.parseError %}disabled title="File contains invalid JSON"{% endif %}>
                        Stage
                    </button>
                    <button type="button"
                            class="btn small ps-stage-rule-btn"
                            data-rule="{{ file.name }}"
                            data-replace="1"
                            {% if file.parseError %}disabled title="File contains invalid JSON"{% endif %}>
                        Stage+Replace
                    </button>
                    <button type="button"
                            class="btn small ps-delete-rule-btn ps-btn-danger"
                            data-rule="{{ file.name }}"
                            data-total="all">
                        Delete Records
                    </button>
                    <form method="post" style="display:inline;" onsubmit="
                        var n = prompt('New file name (without .json):', '{{ file.name }}-copy');
                        if (!n) return false;
                        this.querySelector('[name=newFileName]').value = n.trim();
                    ">
                        {{ csrfInput() }}
                        {{ actionInput('_priceadjuster/rule-file/duplicate') }}
                        <input type="hidden" name="fileName" value="{{ file.name }}">
                        <input type="hidden" name="newFileName" value="">
                        <button type="submit" class="btn small">Duplicate</button>
                    </form>
                    <form method="post" style="display:inline;">
                        {{ csrfInput() }}
                        {{ actionInput('_priceadjuster/rule-file/delete') }}
                        <input type="hidden" name="fileName" value="{{ file.name }}">
                        <button type="submit"
                                class="btn small ps-btn-danger"
                                onclick="return confirm('Delete {{ file.name }}.json? This cannot be undone.')">
                            Delete File
                        </button>
                    </form>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
{% endif %}
