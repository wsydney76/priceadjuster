{
  "name": "wsydney76/craft-priceadjuster",
  "description": "Enable mass assignment of prices for Craft Commerce 5",
  "type": "craft-plugin",
  "require": {
    "php": ">=8.4",
    "craftcms/cms": "^5.9.0"
  },
  "autoload": {
    "psr-4": {
      "wsydney76\\priceadjuster\\": "src/"
    }
  },
  "extra": {
    "handle": "_priceadjuster",
    "name": "Price Adjuster",
    "developer": "wsydney76",
    "documentationUrl": "",
    "class": "wsydney76\\priceadjuster\\PriceadjusterPlugin"
  },
  "config": {
    "sort-packages": true,
    "platform": {
      "php": "8.2"
    },
    "allow-plugins": {
      "yiisoft/yii2-composer": true,
      "craftcms/plugin-installer": true
    }
  }
}
